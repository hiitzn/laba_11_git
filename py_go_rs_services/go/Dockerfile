FROM golang:1.22-alpine AS builder

RUN apk add --no-cache gcc musl-dev sqlite-dev

WORKDIR /app

# Copy go.mod first; go.sum is generated by `go mod tidy` before building.
# GONOSUMDB and -mod=mod let the builder fetch and verify modules without a
# pre-existing go.sum — acceptable in CI; run `go mod tidy` locally to commit go.sum.
COPY go.mod ./
RUN GONOSUMDB=* GOFLAGS=-mod=mod go mod download

COPY . .
RUN CGO_ENABLED=1 GOOS=linux \
    GONOSUMDB=* GOFLAGS=-mod=mod \
    go build -ldflags="-s -w" -o order-service .

# ── Runtime ──────────────────────────────────────────────────────────────────
FROM alpine:3.19

# curl is required by the docker-compose healthcheck.
RUN apk add --no-cache sqlite-libs curl

WORKDIR /app
COPY --from=builder /app/order-service .

EXPOSE 8080
CMD ["./order-service"]