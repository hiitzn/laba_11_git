# Артефакты сборки — самая тяжёлая папка, исключать обязательно
target/

# Git-история не нужна внутри образа
.git/
.gitignore

# Секреты и локальные переменные окружения
.env
.env.*

# Интеграционные тесты — не нужны в production-образе
tests/

# Документация и вспомогательные файлы
*.md
LICENSE

# Временные файлы редакторов
.idea/
.vscode/
*.swp
*.swo

# Файл БД, если был создан локально при разработке
*.db
data/